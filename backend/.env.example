# ── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/jagat-nairobi

# ── Firebase ─────────────────────────────────────────────────────────────────
